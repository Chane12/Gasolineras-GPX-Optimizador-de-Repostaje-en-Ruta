# =============================================================================
# PYTHON — bytecode & packaging
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
build/
dist/
*.egg-info/
*.egg
.eggs/

# =============================================================================
# VIRTUAL ENVIRONMENTS — cualquier nombre
# =============================================================================
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.virtualenvs/

# =============================================================================
# VARIABLES DE ENTORNO Y SECRETOS
# =============================================================================
.env
.env.*
*.env
secrets.toml

# =============================================================================
# DATOS ESPACIALES — política estricta de privacidad
# Ningún dato espacial, track GPS ni dataset descargado entra en el repo
# =============================================================================

# Tracks GPS
*.gpx

# Datasets tabulares
*.csv
*.parquet
*.geoparquet

# GeoJSON / JSON
*.geojson
# *.json  # Desactivado: package-lock.json y configs legítimos usan .json

# Bases de datos
*.sqlite
*.sqlite3
*.db

# Shapefiles (todos los archivos asociados)
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.sbn
*.sbx

# GeoPackage
*.gpkg

# KML / KMZ
*.kml
*.kmz

# Raster
*.tif
*.tiff
*.geotiff

# =============================================================================
# MAPAS Y HTML GENERADOS
# =============================================================================
*.html
mapa_*.html
output_*.html

# =============================================================================
# DIRECTORIOS DE DATOS Y OUTPUT
# =============================================================================
data/
output/
maps/
cache/

# =============================================================================
# TESTING Y LINTING
# =============================================================================
.pytest_cache/
.ruff_cache/
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
coverage.xml
nosetests.xml
*.cover

# =============================================================================
# JUPYTER
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# IDE Y EDITORES
# =============================================================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*~

# =============================================================================
# SISTEMA OPERATIVO
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# LOGS Y TEMPORALES
# =============================================================================
*.log
*.tmp
*.bak

# =============================================================================
# EXCEPCIONES — archivos que SÍ deben entrar al repo
# =============================================================================

# El GPX demo que incluye la app
!sierra_gredos.gpx

# El fixture de test (GPX mínimo para regresión)
!tests/fixtures/sample_track.gpx

# uv.lock DEBE estar en el repo (determinismo de dependencias)
# pyproject.toml DEBE estar en el repo